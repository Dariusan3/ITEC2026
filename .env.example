# Copy to .env in repo root (server loads ../.env)

# Sandbox images: force arch if you see "exec format error" (e.g. DOCKER_PLATFORM=linux/amd64 on Intel/AMD PC)
# DOCKER_PLATFORM=linux/amd64

GROQ_API_KEY=
# Optional — legacy; server uses Groq, not Anthropic
# ANTHROPIC_API_KEY=

# Prefer 127.0.0.1 on Windows if localhost resolves to IPv6-only
REDIS_URL=redis://127.0.0.1:6379
PORT=3001
# Yjs sync WebSocket. On Windows, 1234 may fail with EACCES — match VITE_WS_PORT.
WS_PORT=18766
VITE_WS_PORT=18766

# Shared terminal WebSocket. On Windows, 1235 may fail with EACCES — match VITE_TERM_WS_PORT.
TERM_WS_PORT=18765
VITE_TERM_WS_PORT=18765

# Preview Docker: ms până la primul răspuns HTTP (implicit 540000 = 9 min). Mărește dacă npm install e lent.
# PREVIEW_READY_TIMEOUT_MS=900000
